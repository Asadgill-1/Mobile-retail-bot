# =====================================================================
# .env.example — copy to .env and fill in. NEVER commit .env.
# See docs/11-API-CONTRACTS.md (LLM table) and ADR-001..004.
# =====================================================================

# --- App ---
APP_NAME=multi-shop-chatbot
ENV=dev
LOG_LEVEL=INFO
INTERNAL_API_KEY=change-me-internal-key

# --- Supabase (ADR-001, ADR-003) ---
# Get these from your Supabase project: Project Settings > API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt   # backend only, RLS bypass; NEVER expose to clients
SUPABASE_ANON_KEY=your-anon-jwt
SUPABASE_STORAGE_BUCKET=shop-media
SUPABASE_MGMT_TOKEN=sbp_your-mgmt-pat   # account-level PAT for Management API / migrations (optional)

# --- Redis (ADR-001) ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram (ADR-002, ADR-005) ---
# TELEGRAM_BOT_TOKEN = the OWNER control bot (admin commands).
TELEGRAM_BOT_TOKEN=123456:ABC-your-owner-bot-token
OWNER_TELEGRAM_ID=100000001
# Global rider bot (delivery assignments); leave empty to disable the rider bot.
TELEGRAM_RIDER_BOT_TOKEN=
# Global shop-owner bot (client owners' remote reports); leave empty to disable.
TELEGRAM_SHOPOWNER_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USE_WEBHOOK=false   # false = long-polling (testing)
# Per-shop bots (ADR-005): JSON list, one entry per shop.
# Each shop gets a shopkeeper bot (staff side) + a customer bot (customer-facing).
# customer_chat_id = the Telegram user account that plays that shop's customer in testing.
TELEGRAM_SHOP_BOTS_JSON=[{"shop_key":"shop1","keeper_token":"111:AAA","customer_token":"222:BBB","customer_chat_id":100000001},{"shop_key":"shop2","keeper_token":"333:CCC","customer_token":"444:DDD","customer_chat_id":100000002}]

# --- Twilio / WhatsApp (ADR-002; activated at Stage 13) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_WHATSAPP_FROM=
WHATSAPP_WEBHOOK_BASE_URL=
WHATSAPP_MOCKED=true   # keep true during testing

# --- LLM provider (ADR-004 rev.2) ---
# Testing: official Moonshot API, direct (no OpenRouter middleman).
# Production: OpenAI GPT-4o direct (flip at Stage 12).
#
# Endpoint: api.moonshot.ai is the GLOBAL endpoint. api.moonshot.cn is China-only
# and rejects global keys with 401.
# Models: kimi-k2.5 / kimi-k2.6 (general chat, tool-calling), moonshot-v1-{8k,32k,128k}.
#   kimi-k2.7-code* are code-specialised — do NOT use them for customer chat.
#
# ⚠ TEMPERATURE: kimi-k2.* rejects any temperature except 1 (HTTP 400 "only 1 is allowed").
#   A wrong value fails every message, retries once, then returns the fallback reply —
#   loud in the logs, silent to the customer. Use 1.0 with kimi-k2.*; ~0.2 with GPT-4o.
AI_PROVIDER=moonshot
AI_BASE_URL=https://api.moonshot.ai/v1
AI_API_KEY=sk-your-moonshot-key
AI_MODEL=kimi-k2.6
AI_TEMPERATURE=1.0
AI_MAX_TOKENS=1024
AI_REQUEST_TIMEOUT=30
# Production (Stage 12):
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o
# AI_TEMPERATURE=0.2
# Alt (aggregator): AI_PROVIDER=openrouter, AI_BASE_URL=https://openrouter.ai/api/v1,
#                   AI_MODEL=moonshotai/kimi-k2

# --- Celery / Flower (ADR-001; §13) ---
CELERY_BROKER_URL=            # defaults to REDIS_URL if empty
CELERY_RESULT_BACKEND=        # defaults to REDIS_URL if empty
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flower
